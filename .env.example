# =========================
# 🔑 API KEYS
# =========================

OPENAI_API_KEY=your_openai_api_key_here
SCHOLARSHIP_API_KEY=your_scholarship_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here


# =========================
# 📊 LANGSMITH (Tracing)
# =========================

LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=scholarship-bot


# =========================
# ⚙️ OPTIONAL SETTINGS
# =========================

# OpenAI Model (default used in code)
OPENAI_MODEL=gpt-4o-mini

# App Config
APP_ENV=development
LOG_LEVEL=info
